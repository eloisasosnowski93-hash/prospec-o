# ─── APIs de Enriquecimento ───────────────────────────────────────────
# Serper.dev (Google Search API) — https://serper.dev
# Plano gratuito: 2.500 buscas/mês
SERPER_API_KEY=

# Hunter.io (Email Finder) — https://hunter.io
# Plano gratuito: 25 buscas/mês | Starter: 500/mês (~$49)
HUNTER_API_KEY=

# Apollo.io (B2B Contact Search) — https://apollo.io
# Plano gratuito: 10k créditos/mês | Basic: 75k/mês (~$49)
APOLLO_API_KEY=

# ─── Segurança da API REST ────────────────────────────────────────────
# Chave para proteger o endpoint /prospectar
# Gere com: python3 -c "import secrets; print(secrets.token_hex(32))"
PROSPEC_API_KEY=
